# Example DB URL (set via environment, not committed)
# Postgres (recommended): postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://user:password@host:5432/riderdb
JWT_SECRET=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
